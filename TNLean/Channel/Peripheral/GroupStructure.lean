import TNLean.Channel.Peripheral.CyclicDecomposition
import Mathlib.RingTheory.RootsOfUnity.Basic
import Mathlib.GroupTheory.SpecificGroups.Cyclic
import Mathlib.Analysis.Matrix.Spectrum

/-!
# Peripheral eigenvalue group structure (Wolf Theorem 6.6)

This file establishes that the peripheral eigenvalues of an irreducible
quantum channel form a **cyclic group** under multiplication, completing
the formalization of Wolf Theorem 6.6.

## Building blocks (already formalized elsewhere)

The proof combines three ingredients that already exist:

1. **Peripheral eigenvalues are roots of unity** вҖ” proved in
   `Channel/Peripheral/ClosureFixedPoint.lean` as
   `peripheral_isRootOfUnity_of_irreducible_unital_of_adjoint_fixedPoint`

2. **Finite subgroups of `в„Ӯ*` consisting of roots of unity are cyclic** вҖ”
   Mathlib's `rootsOfUnity.isCyclic` in `RingTheory/RootsOfUnity/Basic.lean`

3. **Peripheral unitaries and cyclic projections** вҖ” proved in
   `Channel/Peripheral/CyclicDecomposition.lean` via
   `exists_peripheral_unitary_of_irreducible_schwarz` and
   `exists_cyclic_projections_of_peripheral_unitary`

## Main results

* `peripheral_eigenvalues_closed_under_mul` вҖ” closure under multiplication
* `peripheral_eigenvalues_closed_under_inv` вҖ” closure under inversion
* `peripheral_eigenvalues_form_cyclic_group` вҖ” the full cyclic group structure
* `peripheral_eigenvalue_multiplicity_one` вҖ” each eigenvalue has multiplicity 1
* `channel_period_divides_dim` вҖ” period divides bond dimension

## References

* [M. Wolf, *Quantum Channels & Operations: Guided Tour*, Section 6.2, Theorem 6.6]
* [Evans, HГёegh-Krohn, *Spectral properties of positive maps*, 1978]
-/

open scoped Matrix ComplexOrder MatrixOrder BigOperators
open Matrix Finset Complex

variable {D : в„•}

namespace PeripheralSpectrum

/-! ### Summary

This namespace collects the key results on peripheral eigenvalues of irreducible
quantum channels:

* **Closure under multiplication and inversion** вҖ” the peripheral spectrum is a
  subgroup of `в„ӮЛЈ`.
* **Cyclic group structure** (Wolf Theorem 6.6) вҖ” that subgroup is cyclic,
  generated by a single root of unity.
* **Multiplicity-one result** вҖ” every peripheral eigenvalue has algebraic
  multiplicity one.
* **Period-divides-dimension bound** вҖ” the period (order of the cyclic group)
  divides the bond dimension `D`.
-/

/-! ## Auxiliary lemmas for the divisibility proof -/

/-- The trace of an orthogonal projection (Hermitian idempotent matrix) over `в„Ӯ` is a natural
number вҖ” it equals the number of unit eigenvalues. -/
private lemma exists_natCast_eq_trace_of_orthogonal_projection
    (P : Matrix (Fin D) (Fin D) в„Ӯ) (hP : IsOrthogonalProjection P) :
    вҲғ n : в„•, Matrix.trace P = (n : в„Ӯ) := by
  classical
  have hH := hP.1
  -- Eigenvalues of P satisfy О»ВІ = О» (from PВІ = P and the spectral decomposition)
  have heig_sq : вҲҖ i : Fin D, (hH.eigenvalues i) ^ 2 = hH.eigenvalues i := by
    intro i
    -- The spectral theorem: P = U diag(О») UвҒ»В№
    have hspec := hH.spectral_theorem
    -- P * P expressed via spectral decomposition:
    -- P * P = U diag(О»ВІ) UвҒ»В№
    open Unitary in
    have hP2 : P * P = (conjStarAlgAut в„Ӯ _ hH.eigenvectorUnitary)
        (Matrix.diagonal (fun j => ((hH.eigenvalues j : в„Ӯ) ^ 2))) := by
      have : P * P =
          (conjStarAlgAut в„Ӯ _ hH.eigenvectorUnitary)
            (Matrix.diagonal (RCLike.ofReal вҲҳ hH.eigenvalues)) *
          (conjStarAlgAut в„Ӯ _ hH.eigenvectorUnitary)
            (Matrix.diagonal (RCLike.ofReal вҲҳ hH.eigenvalues)) :=
        congr_argвӮӮ (В· * В·) hspec hspec
      rw [this, вҶҗ map_mul, Matrix.diagonal_mul_diagonal]
      congr 1; ext j; simp [Function.comp, sq]
    -- P * P = P, so diag(О»ВІ) = diag(О»), hence О»_iВІ = О»_i
    open Unitary in
    have hdiag_eq := (conjStarAlgAut в„Ӯ _ hH.eigenvectorUnitary).injective
        (hP2.symm.trans (hP.2.trans hspec))
    have hi := congr_fun (congr_fun hdiag_eq i) i
    simp only [Matrix.diagonal_apply_eq, Function.comp_apply] at hi
    -- hi : (вҶ‘(eigenvalues i))^2 = вҶ‘(eigenvalues i), goal: eigenvalues i ^ 2 = eigenvalues i
    have hinj : Function.Injective (RCLike.ofReal (K := в„Ӯ)) := RCLike.ofReal_injective
    apply hinj; push_cast; exact hi
  -- Eigenvalues are 0 or 1 (from О»ВІ = О», i.e., О»(О»-1) = 0)
  have heig : вҲҖ i : Fin D, hH.eigenvalues i = 0 вҲЁ hH.eigenvalues i = 1 := by
    intro i
    have h := heig_sq i
    have : hH.eigenvalues i * (hH.eigenvalues i - 1) = 0 := by nlinarith
    rcases mul_eq_zero.mp this with h0 | h1
    В· left; exact h0
    В· right; linarith
  -- Trace = sum of eigenvalues = count of eigenvalues equal to 1
  rw [hH.trace_eq_sum_eigenvalues]
  refine вҹЁ(Finset.univ.filter (fun i => hH.eigenvalues i = 1)).card, ?_вҹ©
  have hif : вҲҖ i вҲҲ Finset.univ, (hH.eigenvalues i : в„Ӯ) =
      if hH.eigenvalues i = 1 then (1 : в„Ӯ) else 0 := by
    intro i _; rcases heig i with h | h <;> simp [h]
  trans (вҲ‘ i : Fin D, if hH.eigenvalues i = 1 then (1 : в„Ӯ) else 0)
  В· exact Finset.sum_congr rfl hif
  В· rw [Finset.sum_ite, Finset.sum_const_zero, add_zero,
      Finset.sum_const, nsmul_eq_mul, mul_one]

/-- Period divides dimension from cyclic projections with trace-preserving map.

Given `m` orthogonal projections summing to the identity that are cyclically permuted by a
trace-preserving map `E`, we have `m вҲЈ D`. The argument: trace preservation forces all projections
to have equal trace, so `m * tr(PвӮҖ) = tr(I) = D`; since `tr(PвӮҖ) вҲҲ в„•` for any orthogonal
projection, `m вҲЈ D`. -/
private lemma period_dvd_dim_of_cyclic_projections
    {r : в„•} [NeZero D]
    (K : Fin r вҶ’ MatrixAlg D)
    (hTP : KadisonSchwarz.IsTPKraus (d := r) (D := D) K)
    {m : в„•} [NeZero m]
    (P : Fin m вҶ’ MatrixAlg D)
    (hPproj : вҲҖ k, IsOrthogonalProjection (P k))
    (hPsum : вҲ‘ k, P k = 1)
    (hcyclic : вҲҖ k, MPSTensor.transferMap (d := r) (D := D) K (P (k + 1)) = P k) :
    m вҲЈ D := by
  set E := MPSTensor.transferMap (d := r) (D := D) K
  have htrace_pres :
      вҲҖ X : MatrixAlg D, Matrix.trace (E X) = Matrix.trace X := by
    intro X
    simpa [E, MPSTensor.transferMap_apply, KadisonSchwarz.krausMap] using
      (KadisonSchwarz.trace_krausMap_of_tp (D := D) K hTP X)
  have htrace_step : вҲҖ k : Fin m, Matrix.trace (P k) = Matrix.trace (P (k + 1)) := by
    intro k
    calc Matrix.trace (P k)
        = Matrix.trace (E (P (k + 1))) := by rw [вҶҗ hcyclic k]
      _ = Matrix.trace (P (k + 1)) := htrace_pres _
  have htrace_eq : вҲҖ k : Fin m, Matrix.trace (P k) = Matrix.trace (P 0) := by
    intro вҹЁk, hkвҹ©
    induction k with
    | zero => rfl
    | succ n ih =>
      have hn : n < m := by omega
      have hfin : (вҹЁn, hnвҹ© : Fin m) + 1 = вҹЁn + 1, hkвҹ© := by
        ext; simp [Fin.val_add, Nat.mod_eq_of_lt hk]
      rw [вҶҗ hfin, вҶҗ htrace_step вҹЁn, hnвҹ©]
      exact ih hn
  have hsum_trace : вҲ‘ k : Fin m, Matrix.trace (P k) = (D : в„Ӯ) := by
    rw [вҶҗ Matrix.trace_sum, hPsum, Matrix.trace_one, Fintype.card_fin]
  have hmul_trace : (m : в„Ӯ) * Matrix.trace (P 0) = (D : в„Ӯ) := by
    rw [вҶҗ hsum_trace]
    trans (вҲ‘ _k : Fin m, Matrix.trace (P 0))
    В· rw [Finset.sum_const, nsmul_eq_mul, Finset.card_univ, Fintype.card_fin]
    В· exact Finset.sum_congr rfl (fun k _ => (htrace_eq k).symm)
  obtain вҹЁn, hnвҹ© := exists_natCast_eq_trace_of_orthogonal_projection (P 0) (hPproj 0)
  have : (вҶ‘(m * n) : в„Ӯ) = (вҶ‘D : в„Ӯ) := by push_cast; rw [вҶҗ hn]; exact hmul_trace
  exact вҹЁn, (Nat.cast_injective this).symmвҹ©

/-! ## Closure under multiplication -/

/-- **Peripheral eigenvalues are closed under multiplication.**

Follows from `exists_peripheral_unitary_of_irreducible_schwarz`: peripheral
eigenvalues have unitary eigenvectors, and the multiplicative domain property
gives `E(U_Оұ U_ОІ) = E(U_Оұ) E(U_ОІ) = ОұОІ В· U_Оұ U_ОІ`. -/
theorem peripheral_eigenvalues_closed_under_mul
    {r : в„•} [NeZero D]
    (K : Fin r вҶ’ MatrixAlg D)
    (hUnital : KadisonSchwarz.IsUnitalKraus (d := r) (D := D) K)
    (ПҒ : MatrixAlg D) (hПҒ : ПҒ.PosDef)
    (hПҒfix : Kraus.adjointMap K ПҒ = ПҒ)
    (hIrr : IsIrreducibleMap (MPSTensor.transferMap (d := r) (D := D) K))
    {Оұ ОІ : в„Ӯ}
    (hОұ : Оұ вҲҲ peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K))
    (hОІ : ОІ вҲҲ peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K)) :
    (Оұ * ОІ) вҲҲ peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K) := by
  -- Get unitary eigenvectors U_Оұ and U_ОІ from CyclicDecomposition.
  obtain вҹЁUОұ, hUОұвҹ© := MPSTensor.exists_peripheral_unitary_of_irreducible_schwarz
    K hUnital ПҒ hПҒ hПҒfix hIrr hОұ
  obtain вҹЁUОІ, hUОІвҹ© := MPSTensor.exists_peripheral_unitary_of_irreducible_schwarz
    K hUnital ПҒ hПҒ hПҒfix hIrr hОІ
  constructor
  В· -- HasEigenvalue for Оұ * ОІ: product of unitaries is nonzero, and
    -- E(U_Оұ U_ОІ) = Оұ ОІ В· U_Оұ U_ОІ by the multiplicative domain.
    have hUnital' : Kraus.IsUnital K := by
      simpa [Kraus.IsUnital, KadisonSchwarz.IsUnitalKraus] using hUnital
    -- Convert eigenvector eq for UОІ to Kraus.map, then get KS equality
    have hUОІ_map : Kraus.map K (UОІ : MatrixAlg D) = ОІ вҖў (UОІ : MatrixAlg D) := by
      simpa [Kraus.map, MPSTensor.transferMap_apply] using hUОІ
    have hKSОІ_map :=
      Kraus.ks_equality_of_peripheral_eigenvector_of_fixedPoint
        K hUnital' hПҒ hПҒfix _ ОІ hUОІ_map hОІ.2
    have hKSОІ : KadisonSchwarz.krausMap K ((UОІ : MatrixAlg D)бҙҙ * (UОІ : MatrixAlg D)) =
        (KadisonSchwarz.krausMap K (UОІ : MatrixAlg D))бҙҙ *
          KadisonSchwarz.krausMap K (UОІ : MatrixAlg D) := by
      simpa [Kraus.map, KadisonSchwarz.krausMap] using hKSОІ_map
    -- multiplicative_domain_right: E(UОұ В· UОІ) = E(UОұ) В· E(UОІ)
    have hprod_kraus : KadisonSchwarz.krausMap K ((UОұ : MatrixAlg D) * (UОІ : MatrixAlg D)) =
        KadisonSchwarz.krausMap K (UОұ : MatrixAlg D) *
          KadisonSchwarz.krausMap K (UОІ : MatrixAlg D) :=
      KadisonSchwarz.multiplicative_domain_right K hUnital
        (UОІ : MatrixAlg D) hKSОІ (UОұ : MatrixAlg D)
    -- Compute: E(UОұ) В· E(UОІ) = (Оұ В· UОұ)(ОІ В· UОІ) = ОұОІ В· (UОұ В· UОІ)
    have hUОұ_kraus : KadisonSchwarz.krausMap K (UОұ : MatrixAlg D) =
        Оұ вҖў (UОұ : MatrixAlg D) := by
      simpa [KadisonSchwarz.krausMap, MPSTensor.transferMap_apply] using hUОұ
    have hUОІ_kraus : KadisonSchwarz.krausMap K (UОІ : MatrixAlg D) =
        ОІ вҖў (UОІ : MatrixAlg D) := by
      simpa [KadisonSchwarz.krausMap, MPSTensor.transferMap_apply] using hUОІ
    have hprod_transfer : MPSTensor.transferMap (d := r) (D := D) K
        ((UОұ : MatrixAlg D) * (UОІ : MatrixAlg D)) =
        (Оұ * ОІ) вҖў ((UОұ : MatrixAlg D) * (UОІ : MatrixAlg D)) := by
      have : KadisonSchwarz.krausMap K ((UОұ : MatrixAlg D) * (UОІ : MatrixAlg D)) =
          (Оұ * ОІ) вҖў ((UОұ : MatrixAlg D) * (UОІ : MatrixAlg D)) := by
        rw [hprod_kraus, hUОұ_kraus, hUОІ_kraus, smul_mul_assoc, mul_smul_comm, smul_smul]
      simpa [KadisonSchwarz.krausMap, MPSTensor.transferMap_apply] using this
    -- Product of unitaries is nonzero (left-cancel by UОұвҖ )
    have hprod_ne : (UОұ : MatrixAlg D) * (UОІ : MatrixAlg D) вү  0 := by
      intro h
      have hUОұ_inv : (UОұ : MatrixAlg D)бҙҙ * (UОұ : MatrixAlg D) = 1 := by
        have hstar_Оұ := Matrix.UnitaryGroup.star_mul_self UОұ
        rwa [star_eq_conjTranspose] at hstar_Оұ
      have hUОІ_inv : (UОІ : MatrixAlg D)бҙҙ * (UОІ : MatrixAlg D) = 1 := by
        have hstar_ОІ := Matrix.UnitaryGroup.star_mul_self UОІ
        rwa [star_eq_conjTranspose] at hstar_ОІ
      have hUОІ_zero : (UОІ : MatrixAlg D) = 0 := by
        calc (UОІ : MatrixAlg D)
            = 1 * (UОІ : MatrixAlg D) := (one_mul _).symm
          _ = (UОұ : MatrixAlg D)бҙҙ * (UОұ : MatrixAlg D) * (UОІ : MatrixAlg D) := by
                rw [hUОұ_inv]
          _ = (UОұ : MatrixAlg D)бҙҙ * ((UОұ : MatrixAlg D) * (UОІ : MatrixAlg D)) := by
                rw [mul_assoc]
          _ = 0 := by rw [h, mul_zero]
      exact one_ne_zero (by rw [вҶҗ hUОІ_inv, hUОІ_zero, mul_zero])
    exact hasEigenvalue_of_eigenvector_eq _ _ _ hprod_transfer hprod_ne
  В· rw [Complex.norm_mul, hОұ.2, hОІ.2, mul_one]

/-- **Peripheral eigenvalues are closed under inversion.**

For `|Оұ| = 1`, we have `ОұвҒ»В№ = Оұ'`, and `U_ОұвҖ ` is the eigenvector. -/
theorem peripheral_eigenvalues_closed_under_inv
    {r : в„•} [NeZero D]
    (K : Fin r вҶ’ MatrixAlg D)
    (hUnital : KadisonSchwarz.IsUnitalKraus (d := r) (D := D) K)
    (ПҒ : MatrixAlg D) (hПҒ : ПҒ.PosDef)
    (hПҒfix : Kraus.adjointMap K ПҒ = ПҒ)
    (hIrr : IsIrreducibleMap (MPSTensor.transferMap (d := r) (D := D) K))
    {Оұ : в„Ӯ}
    (hОұ : Оұ вҲҲ peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K)) :
    ОұвҒ»В№ вҲҲ peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K) := by
  constructor
  В· -- HasEigenvalue for ОұвҒ»В№: UОұвҖ  is the eigenvector
    obtain вҹЁUОұ, hUОұвҹ© := MPSTensor.exists_peripheral_unitary_of_irreducible_schwarz
      K hUnital ПҒ hПҒ hПҒfix hIrr hОұ
    -- E(UОұвҖ ) = (E(UОұ))вҖ  = (Оұ В· UОұ)вҖ  = Оұ' В· UОұвҖ  = ОұвҒ»В№ В· UОұвҖ 
    have hUОұ_map : Kraus.map K (UОұ : MatrixAlg D) = Оұ вҖў (UОұ : MatrixAlg D) := by
      simpa [Kraus.map, MPSTensor.transferMap_apply] using hUОұ
    -- Оұ' = ОұвҒ»В№ when |Оұ| = 1
    have hconj_eq_inv : starRingEnd в„Ӯ Оұ = ОұвҒ»В№ :=
      (Complex.inv_eq_conj hОұ.2).symm
    have hmap_conj : Kraus.map K (UОұ : MatrixAlg D)бҙҙ =
        ОұвҒ»В№ вҖў (UОұ : MatrixAlg D)бҙҙ := by
      rw [вҶҗ Kraus.map_conjTranspose, hUОұ_map, conjTranspose_smul]
      simp only [Complex.star_def, hconj_eq_inv]
    have hconj_transfer : MPSTensor.transferMap (d := r) (D := D) K (UОұ : MatrixAlg D)бҙҙ =
        ОұвҒ»В№ вҖў (UОұ : MatrixAlg D)бҙҙ := by
      simpa [Kraus.map, MPSTensor.transferMap_apply] using hmap_conj
    -- UОұвҖ  is nonzero
    have hUОұ_conj_ne : (UОұ : MatrixAlg D)бҙҙ вү  0 := by
      intro h
      have h1 := Matrix.UnitaryGroup.star_mul_self UОұ
      rw [star_eq_conjTranspose, h, zero_mul] at h1
      exact one_ne_zero h1.symm
    exact hasEigenvalue_of_eigenvector_eq _ _ _ hconj_transfer hUОұ_conj_ne
  В· rw [norm_inv, hОұ.2, inv_one]

/-! ## Cyclic group structure

The proof strategy uses Mathlib's `rootsOfUnity.isCyclic`:

1. By `peripheral_isRootOfUnity_of_irreducible_unital_of_adjoint_fixedPoint`,
   every peripheral eigenvalue `Ој` satisfies `Ој^p = 1` for some `p > 0`.
2. Taking `m = lcm` of all such periods, every peripheral eigenvalue is an
   `m`-th root of unity.
3. The peripheral eigenvalues embed into `rootsOfUnity m в„Ӯ`, which is cyclic
   by Mathlib's `rootsOfUnity.isCyclic`.
4. The period `m` divides `D` via the cyclic projections from
   `CyclicDecomposition.lean`.
-/

/-- **The peripheral eigenvalues form a cyclic group** (Wolf Theorem 6.6, without divisibility).

The peripheral eigenvalues form a finite subset of `в„Ӯ`, contain `1`, and are
closed under multiplication and inversion, so they form a finite subgroup of
`в„ӮЛЈ`, which is cyclic. This lemma extracts the cyclic structure without
requiring `IsTPKraus` (the divisibility `m вҲЈ D` needs trace-preservation
separately; see `peripheral_eigenvalues_form_cyclic_group`). -/
theorem peripheral_eigenvalues_cyclic_structure
    {r : в„•} [NeZero D]
    (K : Fin r вҶ’ MatrixAlg D)
    (hUnital : KadisonSchwarz.IsUnitalKraus (d := r) (D := D) K)
    (ПҒ : MatrixAlg D) (hПҒ : ПҒ.PosDef)
    (hПҒfix : Kraus.adjointMap K ПҒ = ПҒ)
    (hIrr : IsIrreducibleMap (MPSTensor.transferMap (d := r) (D := D) K)) :
    вҲғ (m : в„•) (Оі : в„Ӯ),
      0 < m вҲ§
      IsPrimitiveRoot Оі m вҲ§
      peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K) =
        {z : в„Ӯ | вҲғ k : Fin m, z = Оі ^ (k : в„•)} := by
  classical
  set E := MPSTensor.transferMap (d := r) (D := D) K with hE_def
  -- E is unital: E(1) = 1
  have hE_unital : E 1 = 1 := by
    simp only [hE_def, MPSTensor.transferMap_apply]
    exact KadisonSchwarz.krausMap_one_of_unital K hUnital
  -- 1 is a peripheral eigenvalue (since E(1) = 1 and 1 вү  0)
  have hone_mem : (1 : в„Ӯ) вҲҲ peripheralEigenvalues E :=
    one_mem_peripheralEigenvalues E 1 hE_unital one_ne_zero
  -- Peripheral eigenvalues are finite (finite-dimensional endomorphism)
  have hfin : (peripheralEigenvalues E).Finite := peripheralEigenvalues_finite E
  -- Elements of peripheralEigenvalues are nonzero (they have norm 1)
  have hne_zero : вҲҖ Ој : в„Ӯ, Ој вҲҲ peripheralEigenvalues E вҶ’ Ој вү  0 := by
    intro Ој вҹЁ_, hОј_normвҹ©
    exact norm_ne_zero_iff.mp (by rw [hОј_norm]; exact one_ne_zero)
  -- Step 1: Construct a finite subgroup of в„ӮЛЈ from peripheral eigenvalues
  let periphSubgroup : Subgroup в„ӮЛЈ :=
    { carrier := {u : в„ӮЛЈ | (u : в„Ӯ) вҲҲ peripheralEigenvalues E}
      one_mem' := by change ((1 : в„ӮЛЈ) : в„Ӯ) вҲҲ peripheralEigenvalues E; simpa using hone_mem
      mul_mem' := fun {a b} (ha : (a : в„Ӯ) вҲҲ peripheralEigenvalues E)
          (hb : (b : в„Ӯ) вҲҲ peripheralEigenvalues E) => by
        change (вҶ‘(a * b) : в„Ӯ) вҲҲ peripheralEigenvalues E
        rw [Units.val_mul]
        exact peripheral_eigenvalues_closed_under_mul K hUnital ПҒ hПҒ hПҒfix hIrr ha hb
      inv_mem' := fun {a} (ha : (a : в„Ӯ) вҲҲ peripheralEigenvalues E) => by
        change (вҶ‘(aвҒ»В№) : в„Ӯ) вҲҲ peripheralEigenvalues E
        rw [Units.val_inv_eq_inv_val]
        exact peripheral_eigenvalues_closed_under_inv K hUnital ПҒ hПҒ hПҒfix hIrr ha }
  -- Step 2: The subgroup is finite (image in в„Ӯ lands in a finite set)
  haveI hFinS : Finite вҶҘperiphSubgroup := by
    have : Set.Finite {u : в„ӮЛЈ | (u : в„Ӯ) вҲҲ peripheralEigenvalues E} := by
      have hinj : Set.InjOn Units.val (Units.val вҒ»В№' (peripheralEigenvalues E)) :=
        fun _ _ _ _ h => Units.val_injective h
      exact hfin.preimage hinj
    exact this.to_subtype
  -- Step 3: Finite subgroups of в„ӮЛЈ are cyclic.
  haveI : IsCyclic вҶҘperiphSubgroup := isCyclic_subgroup_units periphSubgroup
  -- Step 4: Extract a generator g with orderOf g = |S| = m
  obtain вҹЁg, hg_orderвҹ© := isCyclic_iff_exists_orderOf_eq_natCard.mp вҖ№IsCyclic вҶҘperiphSubgroupвҖә
  set m := Nat.card вҶҘperiphSubgroup with hm_def
  set Оі := (g.val : в„Ӯ) with hОі_def
  -- m > 0 (the subgroup contains at least 1)
  have hm_pos : 0 < m := Nat.card_pos
  -- Step 5: IsPrimitiveRoot Оі m
  have hОі_prim : IsPrimitiveRoot Оі m := by
    constructor
    В· -- Оі^m = 1: g has order m, so g^m = 1
      have hgm : g ^ m = 1 := by rw [вҶҗ hg_order]; exact pow_orderOf_eq_one g
      change (g.val : в„Ӯ) ^ m = 1
      have : ((g ^ m : вҶҘperiphSubgroup).val : в„Ӯ) = ((1 : вҶҘperiphSubgroup).val : в„Ӯ) :=
        congr_arg (fun x => ((x : вҶҘperiphSubgroup).val : в„Ӯ)) hgm
      simp only [SubgroupClass.coe_pow, OneMemClass.coe_one] at this
      exact this
    В· -- вҲҖ l, Оі^l = 1 вҶ’ m вҲЈ l
      intro l hl
      -- Lift (g.val : в„Ӯ)^l = 1 to g.val^l = 1 in в„ӮЛЈ
      have hunits : g.val ^ l = 1 := by
        apply Units.val_injective; push_cast; exact hl
      -- Lift to g^l = 1 in periphSubgroup
      have hgroup : g ^ l = 1 := by
        apply Subtype.val_injective; exact hunits
      rw [вҶҗ hg_order]
      exact orderOf_dvd_of_pow_eq_one hgroup
  -- Step 6: peripheralEigenvalues E = {z | вҲғ k : Fin m, z = Оі ^ k}
  have hset_eq : peripheralEigenvalues E =
      {z : в„Ӯ | вҲғ k : Fin m, z = Оі ^ (k : в„•)} := by
    ext Ој; constructor
    В· -- (вҠҶ): each peripheral eigenvalue is a power of Оі
      intro hОј
      -- Lift Ој to a unit in в„ӮЛЈ
      have hОј_ne := hne_zero Ој hОј
      set u : в„ӮЛЈ := Units.mk0 Ој hОј_ne with hu_def
      -- u вҲҲ periphSubgroup
      have hu_mem : u вҲҲ periphSubgroup := by
        change (u : в„Ӯ) вҲҲ peripheralEigenvalues E
        simp only [hu_def, Units.val_mk0]; exact hОј
      -- Since g generates periphSubgroup, u вҲҲ zpowers g
      have hg_top : Subgroup.zpowers g = вҠӨ :=
        Subgroup.eq_top_of_card_eq _ (by rw [Nat.card_zpowers, hg_order])
      have hu_zpow : (вҹЁu, hu_memвҹ© : вҶҘperiphSubgroup) вҲҲ Subgroup.zpowers g := by
        rw [hg_top]; exact Subgroup.mem_top _
      obtain вҹЁz, hzвҹ© := hu_zpow
      -- Convert integer power to natural number power mod m
      -- g^z = g^(z % m) since g has order m, then z % m вүҘ 0 so toNat works
      have hg_eq : (вҹЁu, hu_memвҹ© : вҶҘperiphSubgroup) = g ^ z := hz.symm
      have hg_mod : g ^ z = g ^ (z % вҶ‘m).toNat := by
        have hm_ne : (m : в„Ө) вү  0 := Int.natCast_ne_zero.mpr (by omega)
        have hmod_cast : z % вҶ‘m = вҶ‘(z % вҶ‘m).toNat :=
          (Int.toNat_of_nonneg (Int.emod_nonneg z hm_ne)).symm
        conv_lhs => rw [вҶҗ zpow_mod_orderOf g z, hg_order]
        rw [hmod_cast, zpow_natCast]
        rfl
      have hz_val : u = g.val ^ (z % вҶ‘m).toNat := by
        have : (вҹЁu, hu_memвҹ© : вҶҘperiphSubgroup).val = (g ^ (z % вҶ‘m).toNat).val := by
          rw [hg_eq, hg_mod]
        simpa using this
      have hk_lt : (z % вҶ‘m).toNat < m := by
        have hm_ne : (m : в„Ө) вү  0 := Int.natCast_ne_zero.mpr (by omega)
        have h1 := Int.emod_lt_of_pos z (by omega : (0 : в„Ө) < m)
        omega
      refine вҹЁвҹЁ(z % вҶ‘m).toNat, hk_ltвҹ©, ?_вҹ©
      simp only [hОі_def]
      calc Ој = (u : в„Ӯ) := by simp [hu_def]
        _ = (g.val ^ (z % вҶ‘m).toNat : в„ӮЛЈ).val := by rw [hz_val]
        _ = ((g.val : в„Ӯ)) ^ (z % вҶ‘m).toNat := by push_cast; rfl
    В· -- (вҠҮ): each Оі^k is a peripheral eigenvalue
      rintro вҹЁk, rflвҹ©
      -- g^k вҲҲ periphSubgroup, so (g^k).val.val вҲҲ peripheralEigenvalues E
      have hgk_sub : (g ^ (k : в„•)).val вҲҲ periphSubgroup :=
        (g ^ (k : в„•)).property
      change ((g.val : в„Ӯ)) ^ (k : в„•) вҲҲ peripheralEigenvalues E
      have : ((g ^ (k : в„•)).val : в„Ӯ) вҲҲ peripheralEigenvalues E := hgk_sub
      simp only [SubgroupClass.coe_pow, Units.val_pow_eq_pow_val] at this
      exact this
  exact вҹЁm, Оі, hm_pos, hОі_prim, hset_eqвҹ©

/-- **The peripheral eigenvalues form a cyclic group** (Wolf Theorem 6.6).

Combines `peripheral_eigenvalues_cyclic_structure` (cyclic group without
trace-preservation) with `channel_period_divides_dim` to additionally
establish `m вҲЈ D`. -/
theorem peripheral_eigenvalues_form_cyclic_group
    {r : в„•} [NeZero D]
    (K : Fin r вҶ’ MatrixAlg D)
    (hUnital : KadisonSchwarz.IsUnitalKraus (d := r) (D := D) K)
    (hTP : KadisonSchwarz.IsTPKraus (d := r) (D := D) K)
    (ПҒ : MatrixAlg D) (hПҒ : ПҒ.PosDef)
    (hПҒfix : Kraus.adjointMap K ПҒ = ПҒ)
    (hIrr : IsIrreducibleMap (MPSTensor.transferMap (d := r) (D := D) K)) :
    вҲғ (m : в„•) (Оі : в„Ӯ),
      0 < m вҲ§
      IsPrimitiveRoot Оі m вҲ§
      m вҲЈ D вҲ§
      peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K) =
        {z : в„Ӯ | вҲғ k : Fin m, z = Оі ^ (k : в„•)} := by
  obtain вҹЁm, Оі, hm_pos, hОі_prim, hset_eqвҹ© :=
    peripheral_eigenvalues_cyclic_structure K hUnital ПҒ hПҒ hПҒfix hIrr
  -- m вҲЈ D via cyclic decomposition
  have hm_dvd : m вҲЈ D := by
    -- Оі is a peripheral eigenvalue (it's Оі^1)
    have hОі_mem : Оі вҲҲ peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K) := by
      rw [hset_eq]
      by_cases hm1 : m = 1
      В· have hОі1 : Оі = 1 := by have := hОі_prim.pow_eq_one; rw [hm1] at this; simpa using this
        exact вҹЁвҹЁ0, by omegaвҹ©, by simp [hОі1]вҹ©
      В· exact вҹЁвҹЁ1, by omegaвҹ©, by simpвҹ©
    -- Convert set representation to Set.range form
    have hperiph_range : peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K) =
        Set.range (fun j : Fin m => Оі ^ (j : в„•)) := by
      rw [hset_eq]; ext x; simp [Set.mem_range, eq_comm]
    haveI : NeZero m := вҹЁby omegaвҹ©
    -- Get cyclic decomposition: m orthogonal projections summing to identity
    obtain вҹЁU, P, _, _, hUm, hPproj, hPsum, _, hcyclicвҹ© :=
      MPSTensor.exists_cyclic_decomposition_of_irreducible_schwarz
        K hUnital ПҒ hПҒ hПҒfix hIrr hОі_prim hperiph_range
    exact period_dvd_dim_of_cyclic_projections K hTP P hPproj hPsum hcyclic
  exact вҹЁm, Оі, hm_pos, hОі_prim, hm_dvd, hset_eqвҹ©

/-- **Each peripheral eigenvalue has multiplicity 1** (Wolf Theorem 6.6).

Follows from `fixed_eq_scalar_of_irreducible_unital` in
`CyclicDecomposition.lean`: if `E(X) = X` with `E` irreducible and unital,
then `X = c В· I`. Applied to `E^m` restricted to a cyclic sector, this
forces one-dimensional eigenspaces. -/
theorem peripheral_eigenvalue_multiplicity_one
    {r : в„•} [NeZero D]
    (K : Fin r вҶ’ MatrixAlg D)
    (hUnital : KadisonSchwarz.IsUnitalKraus (d := r) (D := D) K)
    (ПҒ : MatrixAlg D) (hПҒ : ПҒ.PosDef)
    (hПҒfix : Kraus.adjointMap K ПҒ = ПҒ)
    (hIrr : IsIrreducibleMap (MPSTensor.transferMap (d := r) (D := D) K))
    {Оі : в„Ӯ}
    (hОі : Оі вҲҲ peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K)) :
    Module.finrank в„Ӯ
      (Module.End.eigenspace (MPSTensor.transferMap (d := r) (D := D) K) Оі) = 1 := by
  classical
  set E := MPSTensor.transferMap (d := r) (D := D) K
  obtain вҹЁU, hU_eigвҹ© := MPSTensor.exists_peripheral_unitary_of_irreducible_schwarz
    K hUnital ПҒ hПҒ hПҒfix hIrr hОі
  have hU_ne : (U : MatrixAlg D) вү  0 := by
    intro hU0
    have hstar := Matrix.UnitaryGroup.star_mul_self U
    simp [hU0] at hstar
  have hU_mem : (U : MatrixAlg D) вҲҲ Module.End.eigenspace E Оі :=
    Module.End.mem_eigenspace_iff.mpr (by simpa [E] using hU_eig)
  have heig_le :
      Module.End.eigenspace E Оі вүӨ
        Submodule.span в„Ӯ ({(U : MatrixAlg D)} : Set (MatrixAlg D)) := by
    intro X hX
    have hX_eig : E X = Оі вҖў X := Module.End.mem_eigenspace_iff.mp hX
    have hU_map : Kraus.map K (U : MatrixAlg D) = Оі вҖў (U : MatrixAlg D) := by
      simpa [Kraus.map, E, MPSTensor.transferMap_apply] using hU_eig
    have hОі_inv : (starRingEnd в„Ӯ) Оі = ОівҒ»В№ := (Complex.inv_eq_conj hОі.2).symm
    have hUstar_map : Kraus.map K ((U : MatrixAlg D)бҙҙ) = ОівҒ»В№ вҖў ((U : MatrixAlg D)бҙҙ) := by
      rw [вҶҗ Kraus.map_conjTranspose, hU_map, conjTranspose_smul]
      simp [hОі_inv]
    have hОіinv_norm : вҖ–ОівҒ»В№вҖ– = 1 := by
      rw [norm_inv, hОі.2, inv_one]
    have hUnital' : Kraus.IsUnital K := by
      simpa [Kraus.IsUnital, KadisonSchwarz.IsUnitalKraus] using hUnital
    have hKS_Ustar_map :
        Kraus.map K (((U : MatrixAlg D)бҙҙ)бҙҙ * (U : MatrixAlg D)бҙҙ) =
          (Kraus.map K ((U : MatrixAlg D)бҙҙ))бҙҙ *
            Kraus.map K ((U : MatrixAlg D)бҙҙ) :=
      Kraus.ks_equality_of_peripheral_eigenvector_of_fixedPoint
        K hUnital' hПҒ hПҒfix ((U : MatrixAlg D)бҙҙ) (ОівҒ»В№) hUstar_map hОіinv_norm
    have hKS_Ustar :
        KadisonSchwarz.krausMap K (((U : MatrixAlg D)бҙҙ)бҙҙ * (U : MatrixAlg D)бҙҙ) =
          (KadisonSchwarz.krausMap K ((U : MatrixAlg D)бҙҙ))бҙҙ *
            KadisonSchwarz.krausMap K ((U : MatrixAlg D)бҙҙ) := by
      simpa [Kraus.map, KadisonSchwarz.krausMap] using hKS_Ustar_map
    have hmul_map :
        KadisonSchwarz.krausMap K (X * (U : MatrixAlg D)бҙҙ) =
          KadisonSchwarz.krausMap K X *
            KadisonSchwarz.krausMap K ((U : MatrixAlg D)бҙҙ) :=
      KadisonSchwarz.multiplicative_domain_right K hUnital
        ((U : MatrixAlg D)бҙҙ) hKS_Ustar X
    have hUstar_eig : E ((U : MatrixAlg D)бҙҙ) = ОівҒ»В№ вҖў ((U : MatrixAlg D)бҙҙ) := by
      simpa [E, Kraus.map, MPSTensor.transferMap_apply] using hUstar_map
    have hXU_fix : E (X * (U : MatrixAlg D)бҙҙ) = X * (U : MatrixAlg D)бҙҙ := by
      calc
        E (X * (U : MatrixAlg D)бҙҙ)
            = E X * E ((U : MatrixAlg D)бҙҙ) := by
                simpa [E, MPSTensor.transferMap_apply, KadisonSchwarz.krausMap] using hmul_map
        _ = (Оі вҖў X) * (ОівҒ»В№ вҖў ((U : MatrixAlg D)бҙҙ)) := by rw [hX_eig, hUstar_eig]
        _ = ((Оі * ОівҒ»В№ : в„Ӯ)) вҖў (X * (U : MatrixAlg D)бҙҙ) := by
              rw [smul_mul_assoc, mul_smul_comm, smul_smul]
        _ = X * (U : MatrixAlg D)бҙҙ := by
              have hОі_ne : Оі вү  0 := by
                intro hОі0
                simpa [hОі0] using hОі.2
              simp [hОі_ne]
    obtain вҹЁc, hcвҹ© := MPSTensor.fixed_eq_scalar_of_irreducible_unital
      (K := K) hUnital hIrr (X * (U : MatrixAlg D)бҙҙ) hXU_fix
    have hX_eq : X = c вҖў (U : MatrixAlg D) := by
      have hstar := Matrix.UnitaryGroup.star_mul_self U
      rw [star_eq_conjTranspose] at hstar
      calc
        X = X * (1 : MatrixAlg D) := by simp
        _ = X * (((U : MatrixAlg D)бҙҙ) * (U : MatrixAlg D)) := by rw [hstar]
        _ = (X * (U : MatrixAlg D)бҙҙ) * (U : MatrixAlg D) := by rw [Matrix.mul_assoc]
        _ = (c вҖў (1 : MatrixAlg D)) * (U : MatrixAlg D) := by rw [hc]
        _ = c вҖў (U : MatrixAlg D) := by simp
    exact Submodule.mem_span_singleton.mpr вҹЁc, hX_eq.symmвҹ©
  have hspan_le :
      Submodule.span в„Ӯ ({(U : MatrixAlg D)} : Set (MatrixAlg D)) вүӨ
        Module.End.eigenspace E Оі := by
    refine Submodule.span_le.mpr ?_
    intro X hX
    rcases hX with rfl
    exact hU_mem
  have heig_eq :
      Module.End.eigenspace E Оі =
        Submodule.span в„Ӯ ({(U : MatrixAlg D)} : Set (MatrixAlg D)) :=
    le_antisymm heig_le hspan_le
  rw [heig_eq]
  simpa using finrank_span_singleton (K := в„Ӯ) (v := (U : MatrixAlg D)) hU_ne

/-- The **period** of the channel divides `D` (the bond dimension).

Here `m` is the order of the peripheral eigenvalue group: `Оі` is a primitive
`m`-th root of unity that generates **all** peripheral eigenvalues via `hgen`.
Without `hgen`, the statement would be trivially satisfiable with `m=1, Оі=1`.

Follows from `exists_cyclic_projections_of_peripheral_unitary` in
`CyclicDecomposition.lean`: the `m` mutually orthogonal projections summing
to `I` force each to have rank `D/m`. -/
theorem channel_period_divides_dim
    {r : в„•} [NeZero D]
    (K : Fin r вҶ’ MatrixAlg D)
    (hUnital : KadisonSchwarz.IsUnitalKraus (d := r) (D := D) K)
    (hTP : KadisonSchwarz.IsTPKraus (d := r) (D := D) K)
    (ПҒ : MatrixAlg D) (hПҒ : ПҒ.PosDef)
    (hПҒfix : Kraus.adjointMap K ПҒ = ПҒ)
    (hIrr : IsIrreducibleMap (MPSTensor.transferMap (d := r) (D := D) K))
    {m : в„•} {Оі : в„Ӯ} (hm : 0 < m)
    (hОіprim : IsPrimitiveRoot Оі m)
    (_hОі : Оі вҲҲ peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K))
    (hgen : peripheralEigenvalues (MPSTensor.transferMap (d := r) (D := D) K) =
      {z : в„Ӯ | вҲғ k : Fin m, z = Оі ^ (k : в„•)}) :
    m вҲЈ D := by
  -- Get cyclic decomposition
  set E := MPSTensor.transferMap (d := r) (D := D) K
  haveI : NeZero m := вҹЁby omegaвҹ©
  have hperiph_range : peripheralEigenvalues E =
      Set.range (fun j : Fin m => Оі ^ (j : в„•)) := by
    rw [hgen]; ext x; simp [Set.mem_range, eq_comm]
  obtain вҹЁU, P, _, _, hUm, hPproj, hPsum, _, hcyclicвҹ© :=
    MPSTensor.exists_cyclic_decomposition_of_irreducible_schwarz
      K hUnital ПҒ hПҒ hПҒfix hIrr hОіprim hperiph_range
  exact period_dvd_dim_of_cyclic_projections K hTP P hPproj hPsum hcyclic

end PeripheralSpectrum
