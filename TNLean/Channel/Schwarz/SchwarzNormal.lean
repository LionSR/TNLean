import TNLean.Channel.Schwarz.PositiveOnAbelian

/-!
# Schwarz inequality for normal operators

This file records a direct CP/Kraus corollary of KadisonвЂ“Schwarz for normal
operators and states the abstract positive-map version of Wolf Proposition 5.1.

## Main results

* `KadisonSchwarz.kadison_schwarz_normal_cp`
* `KadisonSchwarz.kadison_schwarz_normal_cp_le`
* `KadisonSchwarz.schwarz_inequality_normal_operator`

## References

* [M. Wolf, *Quantum Channels & Operations: Guided Tour*, Proposition 5.1][Wolf2012QChannels]
-/

open scoped Matrix ComplexOrder MatrixOrder
open Matrix Finset

namespace KadisonSchwarz

variable {d D : в„•}

@[simp] theorem krausAdjointMap_conjTranspose
    (K : Fin d в†’ Matrix (Fin D) (Fin D) в„‚)
    (X : Matrix (Fin D) (Fin D) в„‚) :
    krausAdjointMap K (Xбґґ) = (krausAdjointMap K X)бґґ := by
  simp [krausAdjointMap, Matrix.conjTranspose_sum, Matrix.conjTranspose_mul, Matrix.mul_assoc]

/-- Kadison-Schwarz for adjoint Kraus maps, restricted to normal inputs.

This is the CP/Kraus special case of Wolf Proposition 5.1. The normality
assumption is included to match the statement of the proposition, although the
proof does not use it since Kadison-Schwarz already holds for arbitrary inputs. -/
theorem kadison_schwarz_normal_cp (K : Fin d в†’ Matrix (Fin D) (Fin D) в„‚)
    (h_tp : IsTPKraus K)
    (A : Matrix (Fin D) (Fin D) в„‚)
    (_hNormal : Aбґґ * A = A * Aбґґ) :
    (krausAdjointMap K (Aбґґ * A) - krausAdjointMap K (Aбґґ) * krausAdjointMap K A).PosSemidef := by
  simpa using kadison_schwarz_adjoint K h_tp A

/-- Loewner-order reformulation of `kadison_schwarz_normal_cp`. -/
theorem kadison_schwarz_normal_cp_le (K : Fin d в†’ Matrix (Fin D) (Fin D) в„‚)
    (h_tp : IsTPKraus K)
    (A : Matrix (Fin D) (Fin D) в„‚)
    (hNormal : Aбґґ * A = A * Aбґґ) :
    krausAdjointMap K (Aбґґ) * krausAdjointMap K A в‰¤ krausAdjointMap K (Aбґґ * A) := by
  rw [Matrix.le_iff]
  exact kadison_schwarz_normal_cp K h_tp A hNormal

/-- Wolf Prop. 5.1: Schwarz inequality for normal operators under positive maps.

The proof is delegated to the commutative-domain scaffold in
`TNLean.Channel.Schwarz.PositiveOnAbelian`: one restricts `T` to the
commutative `*`-subalgebra generated by `1`, `A`, `Aбґґ`, and `Aбґґ * A`, invokes
Wolf Prop. 1.6 there, and then reads the result as a Loewner-order inequality. -/
theorem schwarz_inequality_normal_operator
    (T : Matrix (Fin D) (Fin D) в„‚ в†’в‚—[в„‚] Matrix (Fin D) (Fin D) в„‚)
    (hPos : IsPositiveMap T)
    (hSub : T 1 в‰¤ (1 : Matrix (Fin D) (Fin D) в„‚))
    (A : Matrix (Fin D) (Fin D) в„‚)
    (hNormal : Aбґґ * A = A * Aбґґ) :
    (T (Aбґґ * A) - T (Aбґґ) * T A).PosSemidef := by
  rw [в†ђ Matrix.le_iff]
  exact PositiveOnAbelian.map_conjTranspose_mul_map_le_of_normal_of_subunital hPos hNormal hSub

end KadisonSchwarz
