import TNLean.Channel.Semigroup.ReducibleQDS

/-!
# Sufficient Conditions for Quantum Relaxation — Wolf Corollary 7.2

This file formalizes **Wolf Corollary 7.2**: three sufficient conditions that
guarantee a quantum dynamical semigroup `T_t = exp(tL)` is **irreducible**
(and hence primitive, relaxing to a unique full-rank steady state `ρ_∞`).

## Statement (Wolf Corollary 7.2)

For a GKSL generator `L` with Lindblad form `F` (Lindblad operators `{Lⱼ}` and
`κ = iH + ½·Σⱼ Lⱼ†Lⱼ`), the QDS is **not** reducible if any of the following holds:

1. **Full algebra generation.** The ℂ-algebra generated by `{Lⱼ} ∪ {κ}` is
   all of `M_d(ℂ)`.
2. **Hermitian Lindblad span with trivial commutant.** The linear span of `{Lⱼ}`
   is closed under `†`, and its commutant in `M_d(ℂ)` is `ℂ·𝟙`.
3. **Large Lindblad span dimension.** `dim(span{Lⱼ}) > d² − d`.
   Equivalently (via Wolf Thm 7.1 Form ii), `rank(C) > d² − d` for the
   Kossakowski matrix.

## Proof strategy

Each condition is proved by **contraposition** using Wolf Prop 7.6:

- Assume reducibility `IsReducibleQDS F.toLinearMap` = `HasInvariantCompression
  F.toLinearMap`.
- By Prop 7.6(3→4), ∃ nontrivial `P` and Lindblad form `F'` equivalent to `F`
  with all `F'.Lⱼ` and `F'.κ` block-upper-triangular w.r.t. `P`.
- Since two Lindblad forms for the same generator are unitarily equivalent,
  `span{F.Lⱼ} = span{F'.Lⱼ}` — all sit inside the block-upper-triangular space.
- **(1):** The algebra generated by block-upper-triangular generators is a proper
  subalgebra of `M_d(ℂ)`, contradicting full generation.
- **(2):** Block-upper-triangular + self-adjoint-closed ⟹ block-diagonal.
  The projection `P` itself is then a nontrivial element in the commutant,
  contradicting triviality.
- **(3):** Block-upper-triangular matrices span a space of dimension `≤ d² − d`,
  contradicting the large-span assumption.

## Main definitions

* `LindbladForm.kappa` — the `κ` operator of a Lindblad form.
* `LindbladForm.GeneratesFullAlgebra` — condition (1): full algebra generation.
* `LindbladForm.HasSelfAdjointSpan` — condition (2a): span closed under `†`.
* `LindbladForm.HasTrivialCommutant` — condition (2b): commutant is `ℂ·𝟙`.
* `LindbladForm.HasLargeLindbladSpan` — condition (3): `dim(span{Lⱼ}) > d² − d`.

## Main results

* `wolf_cor_7_2_one` — **Cor. 7.2(1)**: full algebra generation ⟹ ¬reducible.
* `wolf_cor_7_2_two` — **Cor. 7.2(2)**: Hermitian span + trivial commutant ⟹ ¬reducible.
* `wolf_cor_7_2_three` — **Cor. 7.2(3)**: large Lindblad span ⟹ ¬reducible.

## Infrastructure gaps (sorries)

The proofs rely on two key algebraic facts that require additional infrastructure:

1. **`lindbladSpan_unique`**: Two Lindblad forms for the same generator have the
   same Lindblad operator span (Wolf Prop 7.4 at the span level).
2. **`blockUpperTriangular_algebra_proper`**: The ℂ-subalgebra generated by
   block-upper-triangular matrices is a proper subalgebra of `M_d(ℂ)`.
3. **`dim_blockUpperTriangular_le`**: The span of block-upper-triangular Lindblad
   operators has dimension `≤ d² − d`.

## References

* [M. Wolf, *Quantum Channels & Operations: Guided Tour*, §7.1.2, Cor. 7.2]
-/

open scoped Matrix ComplexOrder BigOperators NNReal MatrixOrder
open Matrix Finset

noncomputable section

attribute [local instance] Matrix.linftyOpNormedRing
attribute [local instance] Matrix.linftyOpNormedAlgebra

variable {D : ℕ}

local notation "Mat" => Matrix (Fin D) (Fin D) ℂ

/-! ## The κ operator of a Lindblad form -/

/-- The **κ operator** of a Lindblad form: `κ = iH + ½·Σⱼ Lⱼ†Lⱼ`.

This is the non-Hermitian part of the effective Hamiltonian in the generator
decomposition `L(ρ) = Σⱼ Lⱼ ρ Lⱼ† − κρ − ρκ†`.

It appears as the block-upper-triangular constraint in Wolf Prop 7.6 condition (4):
`(1 - P) * κ * P = 0`. -/
def LindbladForm.kappa (F : LindbladForm D) : Mat :=
  Complex.I • F.H + (1 / 2 : ℂ) • ∑ j : Fin F.r, (F.L j)ᴴ * F.L j

/-- Unfolding lemma for `kappa` in the block-upper-triangular condition. -/
theorem LindbladForm.kappa_def (F : LindbladForm D) :
    F.kappa = Complex.I • F.H + (1 / 2 : ℂ) • ∑ j : Fin F.r, (F.L j)ᴴ * F.L j :=
  rfl

/-- The block-upper-triangular condition for `κ` in `HasBlockUpperTriangularLindblad`
coincides with the block-upper-triangularity of `F.kappa`. -/
theorem hasBlockUpperTriangularLindblad_kappa_iff
    {L : Mat →ₗ[ℂ] Mat}
    (h : HasBlockUpperTriangularLindblad L) :
    ∃ (P : Mat) (F : LindbladForm D),
      IsNontrivialProjection P ∧
      L = F.toLinearMap ∧
      (∀ j : Fin F.r, (1 - P) * F.L j * P = 0) ∧
      (1 - P) * F.kappa * P = 0 := by
  obtain ⟨P, F, hP, hL, hLj, hκ⟩ := h
  exact ⟨P, F, hP, hL, hLj, hκ⟩

/-! ## Three sufficient conditions (Wolf Corollary 7.2) -/

/-- **Condition (1): Full algebra generation.**
The ℂ-subalgebra of `M_d(ℂ)` generated by the Lindblad operators `{Lⱼ}` and `κ`
is all of `M_d(ℂ)` (as a ℂ-algebra under +, ·, and ℂ-scalar multiplication). -/
def LindbladForm.GeneratesFullAlgebra (F : LindbladForm D) : Prop :=
  Algebra.adjoin ℂ (Set.range F.L ∪ {F.kappa}) = ⊤

/-- **Condition (2a): Self-adjoint Lindblad span.**
The linear span of the Lindblad operators `{Lⱼ}` is closed under conjugate
transpose: for each `j`, `(F.L j)†` lies in `span{F.L k | k}`. -/
def LindbladForm.HasSelfAdjointSpan (F : LindbladForm D) : Prop :=
  ∀ j : Fin F.r, (F.L j)ᴴ ∈ Submodule.span ℂ (Set.range F.L)

/-- **Condition (2b): Trivial commutant of Lindblad operators.**
Every matrix that commutes with all Lindblad operators is a scalar multiple of
the identity. -/
def LindbladForm.HasTrivialCommutant (F : LindbladForm D) : Prop :=
  ∀ A : Mat, (∀ j : Fin F.r, A * F.L j = F.L j * A) → ∃ c : ℂ, A = c • 1

/-- **Condition (3): Large Lindblad span dimension.**
The (complex) dimension of the linear span of `{Lⱼ}` exceeds `d² − d`.

This is equivalent (via Wolf Thm 7.1 Form ii) to `rank(C) > d² − d` for the
Kossakowski matrix, since `rank(C) = dim(span{Lⱼ})` under the Kossakowski
factorization. -/
def LindbladForm.HasLargeLindbladSpan (F : LindbladForm D) : Prop :=
  D ^ 2 - D < Module.finrank ℂ ↥(Submodule.span ℂ (Set.range F.L))

/-! ## Key infrastructure lemmas -/

/-- **Lindblad span invariance (Wolf Prop 7.4).**
Two Lindblad forms for the same generator have the same Lindblad operator span.

This follows from the unitary-equivalence freedom in the Lindblad representation
(Wolf Proposition 7.4): if `F₁.toLinearMap = F₂.toLinearMap`, there is a unitary
matrix `U` such that `F₁.L j = Σ_k U_{jk} F₂.L k` (up to scalar shifts of the
form `v_j • 1`, which do not affect the traceless part of the span).

**Infrastructure needed**: Formalization of Wolf Prop 7.4 at the level of
submodule spans, which requires identifying the traceless Lindblad operators
and showing the unitary transformation preserves the span. -/
private lemma lindbladSpan_unique
    (F₁ F₂ : LindbladForm D)
    (h : F₁.toLinearMap = F₂.toLinearMap) :
    Submodule.span ℂ (Set.range F₁.L) = Submodule.span ℂ (Set.range F₂.L) := by
  -- Requires: formalization of the Lindblad unitary equivalence (Wolf Prop 7.4)
  -- at the level of submodule spans.
  sorry

/-- **Proper subalgebra from block-upper-triangular generators.**
If every generator in a set `S ⊆ M_d(ℂ)` is block-upper-triangular w.r.t. a
nontrivial projection `P` (i.e., `(1 - P) * A * P = 0` for all `A ∈ S`), then
the ℂ-subalgebra generated by `S` does not equal `M_d(ℂ)`.

**Proof idea**: The set `{A : Mat | (1 - P) * A * P = 0}` is a subalgebra
closed under +, ·, and ℂ-scalar multiplication. The algebra generated by `S` is
therefore contained in this subalgebra, which is a proper subalgebra since it
does not contain any matrix with a nonzero `(1-P)·(·)·P` block. -/
private lemma blockUpperTriangular_algebra_proper
    (P : Mat) (hP : IsNontrivialProjection P)
    (S : Set Mat) (hS : ∀ A ∈ S, (1 - P) * A * P = 0) :
    Algebra.adjoin ℂ S ≠ ⊤ := by
  -- Requires: showing the block-upper-triangular subalgebra is proper.
  -- The subalgebra {A | (1-P)*A*P = 0} is closed under + and * (ring), ℂ-scalar,
  -- contains 1 (since (1-P)*1*P = (1-P)*P = 0 by idempotency), and is strictly
  -- contained in M_d since (1-P) itself is not in it for a nontrivial P.
  sorry

/-- **Dimension bound for block-upper-triangular Lindblad span.**
If all Lindblad operators of `F` are block-upper-triangular w.r.t. a nontrivial
projection `P`, then the dimension of their span is at most `d² − d`.

**Proof idea**: The block-upper-triangular condition `(1-P)*A*P = 0` constrains
the lower-left block of each operator to vanish. For `P` of rank `k` (with
`1 ≤ k ≤ D−1`), the space of block-upper-triangular matrices has dimension
`D² − k(D−k)`. For the Lindblad operators in traceless form (as required by
the Kossakowski representation), the space of traceless block-upper-triangular
matrices has dimension `D² − k(D−k) − 2 ≤ D² − D − 1 ≤ D² − D`. -/
private lemma dim_blockUpperTriangular_le
    (F : LindbladForm D)
    (P : Mat) (hP : IsNontrivialProjection P)
    (hL_but : ∀ j : Fin F.r, (1 - P) * F.L j * P = 0) :
    Module.finrank ℂ ↥(Submodule.span ℂ (Set.range F.L)) ≤ D ^ 2 - D := by
  -- Requires: dimension bound on the space of block-upper-triangular traceless
  -- matrices. The key step is showing that span{F.L j} ⊆ the subspace of
  -- matrices satisfying (1-P)*A*P = 0, which has dimension ≤ D² - D for
  -- any nontrivial P (accounting for the traceless normalization).
  sorry

/-! ## Auxiliary lemmas for condition (2) -/

/-- If `(1-P)*A*P = 0` and `P*A*(1-P) = 0`, then `P` commutes with `A`. -/
private lemma commutes_of_blockDiagonal
    (P : Mat) (hP : IsOrthogonalProjection P)
    (A : Mat) (hUpper : (1 - P) * A * P = 0) (hLower : P * A * (1 - P) = 0) :
    P * A = A * P := by
  -- PA = PAP follows from PA(1-P) = 0: PA - PAP = PA(1-P) = 0
  have hPA : P * A = P * A * P := sub_eq_zero.mp (by
    have : P * A - P * A * P = P * A * (1 - P) := by noncomm_ring
    rw [this]; exact hLower)
  -- AP = PAP follows from (1-P)AP = 0: AP - PAP = (1-P)AP = 0
  have hAP : A * P = P * A * P := sub_eq_zero.mp (by
    have : A * P - P * A * P = (1 - P) * A * P := by noncomm_ring
    rw [this]; exact hUpper)
  rw [hPA, hAP]

/-- If the adjoint of `A` is block-upper-triangular w.r.t. `P`, then `A` is
block-lower-triangular: `P * A * (1 - P) = 0`. -/
private lemma blockLower_of_adjoint_blockUpper
    (P : Mat) (hP : IsOrthogonalProjection P)
    (A : Mat) (hAdj : (1 - P) * Aᴴ * P = 0) :
    P * A * (1 - P) = 0 := by
  -- ((1-P) * A† * P)† = P† * A * (1-P)† = P * A * (1-P) (since P is Hermitian)
  have hP_herm : Pᴴ = P := hP.1
  have hcomp : (1 - P)ᴴ = 1 - P := by
    simp [conjTranspose_sub, hP_herm]
  have h : (P * A * (1 - P))ᴴ = (1 - P) * Aᴴ * P := by
    calc (P * A * (1 - P))ᴴ
        = (1 - P)ᴴ * (P * A)ᴴ := conjTranspose_mul _ _
      _ = (1 - P)ᴴ * (Aᴴ * Pᴴ) := by rw [conjTranspose_mul]
      _ = (1 - P) * (Aᴴ * P) := by rw [hcomp, hP_herm]
      _ = (1 - P) * Aᴴ * P := by rw [Matrix.mul_assoc]
  rw [← h, hAdj, conjTranspose_zero]

/-- A nontrivial idempotent is not a scalar multiple of the identity.

**Proof**: If `P = c • 1` and `P * P = P`, then `c² • 1 = c • 1`, so
`(c² − c) • 1 = 0`. Since `1 ≠ 0` (for `D ≥ 1`), we get `c² − c = 0`,
hence `c = 0` (giving `P = 0`, contradicting `P ≠ 0`) or `c = 1`
(giving `P = 1`, contradicting `P ≠ 1`). For `D = 0`, `Mat` is trivial
so `IsNontrivialProjection P` is vacuously false. -/
private lemma nontrivialProjection_not_scalar
    (P : Mat) (hP : IsNontrivialProjection P) (c : ℂ) : P ≠ c • 1 := by
  intro hPc
  have hIdem : P * P = P := hP.1.2
  -- Substitute P = c • 1 into the idempotent equation
  rw [hPc, smul_mul_assoc, Matrix.one_mul, smul_smul] at hIdem
  -- hIdem : c * c • (1 : Mat) = c • (1 : Mat), i.e., (c * c − c) • 1 = 0
  have hsmul : (c * c - c) • (1 : Mat) = 0 := by
    rw [sub_smul]; exact sub_eq_zero.mpr hIdem
  -- Use smul_eq_zero: either c * c − c = 0, or (1 : Mat) = 0
  rcases smul_eq_zero.mp hsmul with hc | h1
  · -- c * c − c = 0 in ℂ: factor as c * (c − 1) = 0, get c = 0 or c = 1
    have hfact : c * (c - 1) = 0 := by linear_combination hc
    rcases mul_eq_zero.mp hfact with rfl | h
    · exact hP.2.1 (by simp [hPc])
    · exact hP.2.2 (by rw [hPc, sub_eq_zero.mp h, one_smul])
  · -- (1 : Mat) = 0 means D = 0, so Mat is Subsingleton and P = 0
    have hP0 : P = 0 := by
      rcases Nat.eq_zero_or_pos D with rfl | hD
      · exact Subsingleton.elim P 0
      · -- D ≥ 1: identity matrix is nonzero (diagonal entry (0,0) = 1 ≠ 0)
        exfalso
        have : (1 : Mat) ⟨0, hD⟩ ⟨0, hD⟩ = 0 := by
          rw [h1]; simp
        simp [Matrix.one_apply] at this
    exact hP.2.1 hP0

/-! ## Wolf Corollary 7.2 -/

/-- **Wolf Corollary 7.2, Condition (1)**: Full algebra generation implies
the QDS is not reducible.

If the ℂ-algebra generated by `{F.Lⱼ} ∪ {F.κ}` equals `M_d(ℂ)`, then the
quantum dynamical semigroup generated by `F.toLinearMap` is not reducible.

**Proof** (by contraposition): Assume reducibility. By Wolf Prop 7.6(3→4),
there exists a nontrivial `P` and an equivalent Lindblad form `F'` with all
`F'.Lⱼ` and `F'.κ` block-upper-triangular w.r.t. `P`. Since `span{F.Lⱼ} =
span{F'.Lⱼ}` (Wolf Prop 7.4) and `F.κ` is related to `F'.κ` through the same
equivalence, both `F.Lⱼ` and `F.κ` sit inside the proper ℂ-subalgebra of
block-upper-triangular matrices. This contradicts full algebra generation. -/
theorem wolf_cor_7_2_one
    (F : LindbladForm D) (hgen : F.GeneratesFullAlgebra) :
    ¬IsReducibleQDS F.toLinearMap := by
  intro hred
  -- Step 1: F.toLinearMap is a GKSL generator
  have hGKSL : IsGKSLGenerator F.toLinearMap :=
    (gksl_iff_lindbladForm F.toLinearMap).mpr ⟨F, rfl⟩
  -- Step 2: By Wolf Prop 7.6(3→4), get a block-upper-triangular Lindblad form F'
  have hbut : HasBlockUpperTriangularLindblad F.toLinearMap :=
    wolf_prop_7_6_three_implies_four hGKSL hred
  obtain ⟨P, F', hP_nt, hF'_eq, hL_but, hκ_but⟩ := hbut
  -- Step 3: The set {F.L j} ∪ {F.κ} generates only a proper subalgebra
  -- (This requires relating F.L j and F.kappa to F' via Prop 7.4 and showing
  --  they are all block-upper-triangular w.r.t. P.)
  have hproper : Algebra.adjoin ℂ (Set.range F.L ∪ {F.kappa}) ≠ ⊤ := by
    -- The Lindblad spans are equal (Wolf Prop 7.4)
    have hspan_eq := lindbladSpan_unique F F' hF'_eq
    -- F'.L j are block-upper-triangular, and span{F.L j} = span{F'.L j}
    -- Hence every element of span{F.L j} (including F.L j themselves) is block-upper-triangular
    -- The kappa terms are also related via the generator equivalence (sorry: needs infrastructure)
    -- Together, all generators of the algebra are block-upper-triangular w.r.t. P
    -- Block-upper-triangular matrices generate only a proper subalgebra
    apply blockUpperTriangular_algebra_proper P hP_nt
    intro A hA
    rcases Set.mem_union.mp hA with hAL | hAκ
    · -- A = F.L j for some j
      obtain ⟨j, rfl⟩ := hAL
      -- F.L j ∈ span{F.L k | k} = span{F'.L k | k}
      -- Each F'.L k is block-upper-triangular, so span ⊆ {A | (1-P)*A*P = 0}
      -- Hence F.L j is block-upper-triangular
      have hmem : F.L j ∈ Submodule.span ℂ (Set.range F'.L) := by
        rw [← hspan_eq]
        exact Submodule.subset_span ⟨j, rfl⟩
      have hbut_sub : ∀ A ∈ Submodule.span ℂ (Set.range F'.L),
          (1 - P) * A * P = 0 := fun A hA => by
        induction hA using Submodule.span_induction with
        | mem x hx =>
          obtain ⟨k, rfl⟩ := hx
          exact hL_but k
        | zero => simp [Matrix.mul_zero]
        | add x y _ _ hx hy =>
          rw [show (1 - P) * (x + y) * P =
              (1 - P) * x * P + (1 - P) * y * P from by noncomm_ring, hx, hy, add_zero]
        | smul c x _ hx =>
          rw [mul_smul_comm, smul_mul_assoc, hx, smul_zero]
      exact hbut_sub _ hmem
    · -- A = F.kappa
      obtain rfl := Set.mem_singleton_iff.mp hAκ
      -- F.kappa is related to F'.kappa via the Lindblad form equivalence.
      -- Both forms represent the same generator, so their κ operators are equal
      -- up to a Hermitian shift. The block-upper-triangular condition on F'.kappa
      -- propagates to F.kappa via the generator equality.
      -- (This step requires formalizing the Lindblad form change for κ.)
      sorry
  exact hproper hgen

/-- **Wolf Corollary 7.2, Condition (2)**: Hermitian Lindblad span with trivial
commutant implies the QDS is not reducible.

**Proof** (by contraposition): Assume reducibility. By Prop 7.6, get `(P, F')`
block-upper-triangular. Since `span{F.Lⱼ} = span{F'.Lⱼ}`, each `F.Lⱼ` is
block-upper-triangular w.r.t. `P`. Self-adjoint closure implies `(F.Lⱼ)†` is
also in the span, hence also block-upper-triangular. Taking the adjoint shows
`F.Lⱼ` is also block-lower-triangular, hence block-diagonal. Then `P` commutes
with every `F.Lⱼ`, so `P` lies in the commutant. By trivial commutant,
`P = c • 1` for some `c ∈ ℂ`. But as a nontrivial idempotent, `P` cannot equal
any `c • 1`. Contradiction. -/
theorem wolf_cor_7_2_two
    (F : LindbladForm D)
    (hsa : F.HasSelfAdjointSpan)
    (htc : F.HasTrivialCommutant) :
    ¬IsReducibleQDS F.toLinearMap := by
  intro hred
  -- Step 1: Get block-upper-triangular form F'
  have hGKSL : IsGKSLGenerator F.toLinearMap :=
    (gksl_iff_lindbladForm F.toLinearMap).mpr ⟨F, rfl⟩
  have hbut : HasBlockUpperTriangularLindblad F.toLinearMap :=
    wolf_prop_7_6_three_implies_four hGKSL hred
  obtain ⟨P, F', hP_nt, hF'_eq, hL_but, _⟩ := hbut
  -- Step 2: Each F.L j is block-upper-triangular w.r.t. P
  have hspan_eq := lindbladSpan_unique F F' hF'_eq
  have hbut_sub : ∀ A ∈ Submodule.span ℂ (Set.range F'.L),
      (1 - P) * A * P = 0 := fun A hA => by
    induction hA using Submodule.span_induction with
    | mem x hx => obtain ⟨k, rfl⟩ := hx; exact hL_but k
    | zero => simp [Matrix.mul_zero]
    | add x y _ _ hx hy =>
      rw [show (1 - P) * (x + y) * P =
          (1 - P) * x * P + (1 - P) * y * P from by noncomm_ring, hx, hy, add_zero]
    | smul c x _ hx =>
      rw [mul_smul_comm, smul_mul_assoc, hx, smul_zero]
  have hFj_but : ∀ j : Fin F.r, (1 - P) * F.L j * P = 0 := by
    intro j
    apply hbut_sub
    rw [← hspan_eq]
    exact Submodule.subset_span ⟨j, rfl⟩
  -- Step 3: Each F.L j is also block-lower-triangular w.r.t. P
  -- Since (F.L j)ᴴ ∈ span{F.L k} (by self-adjoint span), it is also block-upper-triangular.
  -- The adjoint of a block-upper-triangular matrix is block-lower-triangular.
  have hFj_lower : ∀ j : Fin F.r, P * F.L j * (1 - P) = 0 := by
    intro j
    -- (F.L j)ᴴ ∈ span{F.L k} ⊆ span{F'.L k} (via hspan_eq), which is block-upper-triangular
    have hmem_adj : (F.L j)ᴴ ∈ Submodule.span ℂ (Set.range F'.L) := by
      rw [← hspan_eq]
      exact hsa j
    have hAdj_but : (1 - P) * (F.L j)ᴴ * P = 0 :=
      hbut_sub _ hmem_adj
    exact blockLower_of_adjoint_blockUpper P hP_nt.1 (F.L j) hAdj_but
  -- Step 4: Each F.L j is block-diagonal (P commutes with F.L j)
  have hFj_diag : ∀ j : Fin F.r, P * F.L j = F.L j * P := by
    intro j
    exact commutes_of_blockDiagonal P hP_nt.1 (F.L j) (hFj_but j) (hFj_lower j)
  -- Step 5: P is in the commutant of {F.L j}
  -- By HasTrivialCommutant, ∃ c : ℂ, P = c • 1
  obtain ⟨c, hPc⟩ := htc P hFj_diag
  -- Step 6: P is a nontrivial idempotent, so P ≠ c • 1 for any c ∈ ℂ
  exact nontrivialProjection_not_scalar P hP_nt c hPc

/-- **Wolf Corollary 7.2, Condition (3)**: Large Lindblad span dimension implies
the QDS is not reducible.

**Proof** (by contraposition): Assume reducibility. By Prop 7.6, get `(P, F')`
block-upper-triangular. Since `span{F.Lⱼ} = span{F'.Lⱼ}` (Wolf Prop 7.4) and
`dim(span{F'.Lⱼ}) ≤ d² − d` (block-upper-triangular dimension bound),
we get `dim(span{F.Lⱼ}) ≤ d² − d`, contradicting the assumption. -/
theorem wolf_cor_7_2_three
    (F : LindbladForm D) (hspan : F.HasLargeLindbladSpan) :
    ¬IsReducibleQDS F.toLinearMap := by
  intro hred
  -- Step 1: Get block-upper-triangular form F'
  have hGKSL : IsGKSLGenerator F.toLinearMap :=
    (gksl_iff_lindbladForm F.toLinearMap).mpr ⟨F, rfl⟩
  have hbut : HasBlockUpperTriangularLindblad F.toLinearMap :=
    wolf_prop_7_6_three_implies_four hGKSL hred
  obtain ⟨P, F', hP_nt, hF'_eq, hL_but, _⟩ := hbut
  -- Step 2: span{F.L j} = span{F'.L j} (Wolf Prop 7.4 at span level)
  have hspan_eq : Submodule.span ℂ (Set.range F.L) = Submodule.span ℂ (Set.range F'.L) :=
    lindbladSpan_unique F F' hF'_eq
  -- Step 3: dim(span{F'.L j}) ≤ D² - D (block-upper-triangular bound)
  have hdim_bound : Module.finrank ℂ ↥(Submodule.span ℂ (Set.range F'.L)) ≤ D ^ 2 - D :=
    dim_blockUpperTriangular_le F' P hP_nt hL_but
  -- Step 4: dim(span{F.L j}) ≤ D² - D (via span equality)
  have hcontra : Module.finrank ℂ ↥(Submodule.span ℂ (Set.range F.L)) ≤ D ^ 2 - D := by
    rwa [hspan_eq]
  -- Step 5: Contradiction with hspan : D² - D < dim(span{F.L j})
  exact Nat.lt_irrefl _ (Nat.lt_of_lt_of_le hspan hcontra)

end -- noncomputable section
