import TNLean.Algebra.BurnsideTheorem
import TNLean.MPS.CanonicalForm.Reduction
import TNLean.Wielandt.SpanGrowth.CumulativeSpan

import Mathlib.Algebra.Algebra.Subalgebra.Lattice
import Mathlib.RingTheory.Noetherian.Defs

/-!
# Irreducible actions and generated matrix algebras

This file relates `IsIrreducibleTensor` (no nontrivial invariant orthogonal
projection), irreducible action on `‚Ąā^D`, the algebra generated by the Kraus
operators, and eventual cumulative full matrix span.

The algebraic ingredient is the finite-dimensional complex case of Burnside's
theorem, equivalently Jacobson's density theorem.

## Main definitions

* `MPSTensor.algSpan A`: the unital subalgebra `Algebra.adjoin ‚Ąā (Set.range A)`.
* `MPSTensor.IsInvariantSubmodule A W`: `W ‚Č§ (Fin D ‚Üí ‚Ąā)` is invariant under all `A i`.
* `MPSTensor.IsIrreducibleAction A`: no nontrivial invariant submodule.

## Main results

### Part 1: Algebra span and cumulative span

* `algSpan_mem`, `evalWord_mem_algSpan`, `wordSpan_le_algSpan_toSubmodule`,
  `cumulativeSpan_le_algSpan_toSubmodule`: containment lemmas.
* `mul_mem_cumulativeSpan_add`: closure under multiplication (adding lengths).
* `mem_cumulativeSpan_of_mem_algSpan`: every element of `algSpan A` is in some
  `cumulativeSpan A N` (via `Algebra.adjoin_induction`).
* `exists_cumulativeSpan_eq_top_of_algSpan_eq_top`: `algSpan A = ‚ä§ ‚Üí ‚ąÉ N,
  cumulativeSpan A N = ‚ä§` (via Noetherian chain stabilization).

### Part 2: Invariant submodule characterization

* `isIrreducibleTensor_of_isIrreducibleAction`: `IsIrreducibleTensor` follows from
  `IsIrreducibleAction` (range of an invariant orthogonal projection is invariant).

### Connection summary

The complete chain from `IsIrreducibleTensor A` to cumulative full matrix span:

1. `IsIrreducibleTensor A` ‚Üí `IsIrreducibleAction A` (proved in `IrreducibleTensorAction.lean`)
2. `IsIrreducibleAction A` ‚Üí `algSpan A = ‚ä§` (Burnside/Jacobson density, proved in
   `BurnsideTheorem.lean`)
3. `algSpan A = ‚ä§` ‚Üí `‚ąÉ N, cumulativeSpan A N = ‚ä§` (proved in this file, Part 1)

**Important**: `‚ąÉ N, cumulativeSpan A N = ‚ä§` does NOT imply `IsNormal`.
Counterexample: `A‚āĀ = e‚āĀ‚āā, A‚āā = e‚āā‚āĀ` generates `M‚āā(‚Ąā)` but `wordSpan A n`
alternates. Aperiodicity (e.g., `IsPrimitiveMPS`) is needed for IsNormal.

## References

* Burnside (1905), Proc. London Math. Soc.
* arXiv:0909.5347, Proposition 3
-/

open scoped Matrix ComplexOrder BigOperators
open Matrix MPSTensor

namespace MPSTensor

variable {d D : ‚Ąē}

/-! ## Part 1: Algebra span -/


/-- Every word evaluation lies in the algebra span. -/
theorem evalWord_mem_algSpan (A : MPSTensor d D) (w : List (Fin d)) :
    evalWord A w ‚ąą algSpan A := by
  induction w with
  | nil => exact (algSpan A).one_mem
  | cons i w ih => exact (algSpan A).mul_mem (algSpan_mem A i) ih

/-- The word span at any length is contained in the algebra span (as submodules). -/
theorem wordSpan_le_algSpan_toSubmodule (A : MPSTensor d D) (n : ‚Ąē) :
    wordSpan A n ‚Č§ (algSpan A).toSubmodule := by
  apply Submodule.span_le.mpr
  rintro M ‚ü®ŌÉ, rfl‚ü©
  exact evalWord_mem_algSpan A (List.ofFn ŌÉ)

/-- The cumulative span is contained in the algebra span. -/
theorem cumulativeSpan_le_algSpan_toSubmodule (A : MPSTensor d D) (n : ‚Ąē) :
    cumulativeSpan A n ‚Č§ (algSpan A).toSubmodule := by
  apply Submodule.span_le.mpr
  rintro M ‚ü®w, _, rfl‚ü©
  exact evalWord_mem_algSpan A w

/-! ### Multiplication closure for cumulative span -/

/-- Product of generators lands in the right cumulative span. -/
theorem evalWord_mul_evalWord_mem_cumulativeSpan
    (A : MPSTensor d D)
    {w‚āĀ w‚āā : List (Fin d)} {m n : ‚Ąē}
    (hw‚āĀ : w‚āĀ.length ‚Č§ m) (hw‚āā : w‚āā.length ‚Č§ n) :
    evalWord A w‚āĀ * evalWord A w‚āā ‚ąą cumulativeSpan A (m + n) := by
  rw [‚Üź evalWord_append]
  apply mem_cumulativeSpan_generator
  rw [List.length_append]
  omega

/-- The cumulative span is closed under multiplication (adding lengths). -/
theorem mul_mem_cumulativeSpan_add (A : MPSTensor d D) {m n : ‚Ąē}
    {x y : Matrix (Fin D) (Fin D) ‚Ąā}
    (hx : x ‚ąą cumulativeSpan A m) (hy : y ‚ąą cumulativeSpan A n) :
    x * y ‚ąą cumulativeSpan A (m + n) := by
  -- `cumulativeSpan` is defined as a `span`, so we can use binary span induction.
  refine Submodule.span_induction‚āā
      (s := {M | ‚ąÉ w : List (Fin d), w.length ‚Č§ m ‚ąß M = evalWord A w})
      (t := {M | ‚ąÉ w : List (Fin d), w.length ‚Č§ n ‚ąß M = evalWord A w})
      (p := fun x y _ _ => x * y ‚ąą cumulativeSpan A (m + n))
      ?_ ?_ ?_ ?_ ?_ ?_ ?_
      (by simpa [cumulativeSpan] using hx)
      (by simpa [cumulativeSpan] using hy)
  ¬∑ intro x y hx hy
    rcases hx with ‚ü®w‚āĀ, hw‚āĀ, rfl‚ü©
    rcases hy with ‚ü®w‚āā, hw‚āā, rfl‚ü©
    exact evalWord_mul_evalWord_mem_cumulativeSpan A hw‚āĀ hw‚āā
  ¬∑ intro y _hy
    simp [zero_mul]
  ¬∑ intro x _hx
    simp [mul_zero]
  ¬∑ intro x‚āĀ x‚āā y _ _ _ hx‚āĀ hx‚āā
    simpa [add_mul] using (cumulativeSpan A (m + n)).add_mem hx‚āĀ hx‚āā
  ¬∑ intro x y‚āĀ y‚āā _ _ _ hy‚āĀ hy‚āā
    simpa [mul_add] using (cumulativeSpan A (m + n)).add_mem hy‚āĀ hy‚āā
  ¬∑ intro r x y _ _ hxy
    simpa [smul_mul_assoc] using (cumulativeSpan A (m + n)).smul_mem r hxy
  ¬∑ intro r x y _ _ hxy
    simpa [mul_smul_comm] using (cumulativeSpan A (m + n)).smul_mem r hxy

/-- Every element of the algebra span lies in some cumulative span.

Proven via `Algebra.adjoin_induction`. -/
theorem mem_cumulativeSpan_of_mem_algSpan (A : MPSTensor d D)
    {x : Matrix (Fin D) (Fin D) ‚Ąā} (hx : x ‚ąą algSpan A) :
    ‚ąÉ N : ‚Ąē, x ‚ąą cumulativeSpan A N := by
  induction hx using Algebra.adjoin_induction with
  | mem x hxS =>
    rcases hxS with ‚ü®i, rfl‚ü©
    refine ‚ü®1, ?_‚ü©
    simpa [evalWord] using
      (mem_cumulativeSpan_generator (A := A) (n := 1) (w := [i]) (by simp))
  | algebraMap r =>
    refine ‚ü®0, ?_‚ü©
    simpa [Algebra.algebraMap_eq_smul_one] using
      (cumulativeSpan A 0).smul_mem r (one_mem_cumulativeSpan A 0)
  | add x y _ _ ihx ihy =>
    rcases ihx with ‚ü®Nx, hNx‚ü©
    rcases ihy with ‚ü®Ny, hNy‚ü©
    refine ‚ü®max Nx Ny, ?_‚ü©
    exact (cumulativeSpan A (max Nx Ny)).add_mem
      ((cumulativeSpan_mono' A (le_max_left Nx Ny)) hNx)
      ((cumulativeSpan_mono' A (le_max_right Nx Ny)) hNy)
  | mul x y _ _ ihx ihy =>
    rcases ihx with ‚ü®Nx, hNx‚ü©
    rcases ihy with ‚ü®Ny, hNy‚ü©
    exact ‚ü®Nx + Ny, mul_mem_cumulativeSpan_add A hNx hNy‚ü©

/-- **From algebra span to cumulative span**: if the algebra generated by `{A i}`
is all of `M_D(‚Ąā)`, then the cumulative span reaches ‚ä§ at some finite level.

Uses the Noetherian property of finite-dimensional modules. -/
lemma exists_cumulativeSpan_eq_top_of_algSpan_eq_top (A : MPSTensor d D)
    (h : algSpan A = ‚ä§) :
    ‚ąÉ N : ‚Ąē, cumulativeSpan A N = ‚ä§ := by
  -- Every matrix is in the algebra span, hence in some cumulative span
  have hmem : ‚ąÄ x : Matrix (Fin D) (Fin D) ‚Ąā, x ‚ąą algSpan A := by
    intro x; rw [h]; exact Algebra.mem_top
  have hx : ‚ąÄ x : Matrix (Fin D) (Fin D) ‚Ąā, ‚ąÉ N, x ‚ąą cumulativeSpan A N :=
    fun x => mem_cumulativeSpan_of_mem_algSpan A (hmem x)
  -- The module is Noetherian (finite-dimensional over a field)
  haveI : IsNoetherian ‚Ąā (Matrix (Fin D) (Fin D) ‚Ąā) :=
    isNoetherian_of_isNoetherianRing_of_finite ‚Ąā _
  -- Construct the monotone chain as an order homomorphism
  let f : ‚Ąē ‚Üío Submodule ‚Ąā (Matrix (Fin D) (Fin D) ‚Ąā) :=
    ‚ü®cumulativeSpan A, fun _ _ h => cumulativeSpan_mono' A h‚ü©
  -- Noetherian ‚üĻ the ascending chain stabilizes
  obtain ‚ü®N‚āÄ, hstab‚ü© := (monotone_stabilizes_iff_noetherian.mpr ‚ÄĻ_‚Äļ) f
  -- Show the stable value is ‚ä§.
  refine ‚ü®N‚āÄ, eq_top_iff.mpr ?_‚ü©
  intro x _
  rcases hx x with ‚ü®M, hM‚ü©
  rcases le_total M N‚āÄ with hMN | hNM
  ¬∑ exact (cumulativeSpan_mono' A hMN) hM
  ¬∑ have heq : cumulativeSpan A M = cumulativeSpan A N‚āÄ := (hstab M hNM).symm
    simpa [heq] using hM

/-! ## Part 2: Invariant submodule characterization -/


/-- If `(1 - P) * M * P = 0`, then `M * P = P * (M * P)`. -/
private theorem mul_proj_eq {P M : Matrix (Fin D) (Fin D) ‚Ąā}
    (hinv : (1 - P) * M * P = 0) :
    M * P = P * (M * P) := by
  -- (1 - P) * M * P = ((1 - P) * M) * P = (M - P * M) * P
  --   = M * P - P * M * P = M * P - P * (M * P)
  have h1 : (M - P * M) * P = 0 := by rwa [sub_mul, one_mul] at hinv
  have h2 : M * P - P * M * P = 0 := by rwa [sub_mul] at h1
  have h3 : M * P - P * (M * P) = 0 := by rwa [mul_assoc] at h2
  exact sub_eq_zero.mp h3

/-- `IsIrreducibleAction` implies `IsIrreducibleTensor`.

If there are no nontrivial invariant submodules, then there are no
nontrivial invariant orthogonal projections. -/
lemma isIrreducibleTensor_of_isIrreducibleAction
    (A : MPSTensor d D) (hIrr : IsIrreducibleAction A) :
    IsIrreducibleTensor (d := d) (D := D) A := by
  intro ‚ü®P, horth, hne0, hne1, hinv‚ü©
  let V : Type := Fin D ‚Üí ‚Ąā
  let f : V ‚Üí‚āó[‚Ąā] V := Matrix.toLin' P
  -- The range of `f` is an invariant submodule.
  set W : Submodule ‚Ąā V := LinearMap.range f
  have hW_inv : IsInvariantSubmodule A W := by
    intro i v ‚ü®u, hu‚ü©
    have hAP : A i * P = P * (A i * P) := mul_proj_eq (hinv i)
    refine ‚ü®(A i * P).mulVec u, ?_‚ü©
    simp only [V, f, Matrix.toLin'_apply] at hu ‚äĘ
    rw [Matrix.mulVec_mulVec, ‚Üź hAP, ‚Üź Matrix.mulVec_mulVec, hu]
  rcases hIrr W hW_inv with hW | hW
  ¬∑ -- `W = ‚ä•`: the range is trivial, hence `P = 0`.
    apply hne0
    have hf0 : f = 0 := by
      have : f.range = ‚ä• := by
        simpa [W] using hW
      exact (LinearMap.range_eq_bot).1 this
    have hP0 := congrArg LinearMap.toMatrix' hf0
    simpa [f, LinearMap.toMatrix'_toLin'] using hP0
  ¬∑ -- `W = ‚ä§`: the range is all of `V`, hence `P = 1`.
    apply hne1
    have hsurj : Function.Surjective f := by
      have : f.range = ‚ä§ := by
        simpa [W] using hW
      exact (LinearMap.range_eq_top).1 this
    have hfid : f = LinearMap.id := by
      apply LinearMap.ext
      intro v
      rcases hsurj v with ‚ü®u, rfl‚ü©
      -- Simplify the goal and unfold `f`.
      simp only [f, LinearMap.id_apply]
      have hmul :
          (Matrix.toLin' P) ((Matrix.toLin' P) u) = (Matrix.toLin' (P * P)) u :=
        (Matrix.toLin'_mul_apply P P u).symm
      rw [horth.2] at hmul
      exact hmul
    have hP1 := congrArg LinearMap.toMatrix' hfid
    simpa [V, f, LinearMap.toMatrix'_toLin', LinearMap.toMatrix'_id] using hP1

end MPSTensor
